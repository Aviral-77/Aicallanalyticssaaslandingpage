# Copy this file to backend/.env and fill in your values
# cp .env.example backend/.env

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Optional: LangSmith observability ─────────────────────────────────────────
# Sign up free at https://smith.langchain.com/
# Enables tracing, evaluation, and monitoring of all LLM calls

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=repost-ai

# ── Optional: Tavily web search ───────────────────────────────────────────────
# Get a free API key at https://tavily.com/
# Used to enrich prompts with fresh web context for better posts

TAVILY_API_KEY=tvly-...

# ── Optional overrides ────────────────────────────────────────────────────────

# Override the OpenAI model (default: gpt-4o)
# LLM_MODEL=gpt-4o

# JWT secret — change this in production!
# JWT_SECRET_KEY=your-super-secret-key-at-least-32-chars
